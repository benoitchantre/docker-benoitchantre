# Copy to .env, fill in real values, then: chmod 600 .env
# .env is git-ignored — never commit real secrets.

DB_NAME=fJ1fD4_benoitchantre
DB_USER=fJ1fD4_benoitchantre
DB_PASSWORD=changeme-generate-a-strong-random-password
DB_ROOT_PASSWORD=changeme-generate-a-different-strong-random-password

# Preserve the existing table prefix — the migrated database's tables use
# this prefix. Changing it after import will break the site.
WP_TABLE_PREFIX=wp_9b3iDK4g_

# Extra wp-config.php constants, injected verbatim by the official WordPress
# image's entrypoint. Semicolon-separated PHP statements.
#   - WP_AUTO_UPDATE_CORE 'minor': core security/minor releases auto-update.
#   - DISALLOW_FILE_EDIT: blocks editing theme/plugin files from wp-admin
#     (doesn't affect auto-updates, which don't go through that code path).
#   - DISALLOW_FILE_MODS would also block plugin/theme *install* and
#     updates from wp-admin — deliberately left OFF so plugin auto-updates
#     and Jetpack/security-plugin self-updates keep working. Re-enable if
#     you'd rather manage all plugin changes via deploy instead.
WORDPRESS_CONFIG_EXTRA="define('WP_AUTO_UPDATE_CORE', 'minor'); define('DISALLOW_FILE_EDIT', true); define('DISABLE_WP_CRON', true);"

# SMTP relay (via msmtp — see Dockerfile.php) for outbound WordPress email
# (password resets, notifications, contact-form plugins). Use an app
# password if your provider supports 2FA (Gmail, etc.) rather than your
# real account password.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=changeme
SMTP_FROM=mail@benoitchantre.com
