# msmtp config: relays PHP's mail()/wp_mail() calls through a real SMTP
# provider (set via env vars from .env). Values are substituted by
# docker-entrypoint-msmtp.sh at container start.
defaults
auth           on
tls            on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
logfile        /var/log/msmtp.log

account        default
host           __SMTP_HOST__
port           __SMTP_PORT__
user           __SMTP_USER__
password       __SMTP_PASSWORD__
from           __SMTP_FROM__

aliases        /etc/aliases
