# Secrets
.env
*/.env
*/*/.env

# Runtime data (bind mounts, DB volumes if bind-mounted, cache)
sites/*/wp-content/
**/mysql-data/

# Backups & dumps
backups/
*.sql
*.sql.gz
*.tar.gz

# Let's Encrypt / Caddy runtime state (if ever bind-mounted instead of named volume)
caddy/data/
caddy/config/

# OS cruft
.DS_Store

# Un-ignore: caddy/Caddyfile.local is a tracked local-override config, not
# a machine-local settings file — the global ~/.gitignore's `*.local` rule
# would otherwise silently exclude it.
!caddy/Caddyfile.local

# Un-ignore: mu-plugins are custom code we write, not runtime/user content
# like uploads or wp-admin-installed themes/plugins — track them like any
# other infra config. `sites/*/wp-content/` above is a directory-level
# exclusion, so git won't descend into it at all — every path segment down
# to the files themselves needs its own `!` rule, or later `!` rules are
# silently skipped.
!sites/*/wp-content/
sites/*/wp-content/*
!sites/*/wp-content/mu-plugins/
!sites/*/wp-content/mu-plugins/*.php
