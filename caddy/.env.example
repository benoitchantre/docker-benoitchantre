# Copy to .env and fill in. .env is git-ignored.

# Email used for Let's Encrypt expiry notices.
ACME_EMAIL=benoit@chantre.ch

# API key for the CrowdSec bouncer talking to the crowdsec agent.
# Generate on the host after the crowdsec stack is up:
#   docker exec crowdsec cscli bouncers add caddy-bouncer
# Paste the printed key here.
CROWDSEC_BOUNCER_API_KEY=changeme
